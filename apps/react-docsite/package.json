{
  "name": "@iqvizyonui/react-docsite",
  "version": "1.0.0",
  "private": true,
  "description": "Iqvizyon UI React documentation",
  "scripts": {
    "build-storybook": "cross-env NODE_OPTIONS=--max_old_space_size=3072 DEPLOY_PATH=/iqvui/react/ storybook build -o ./dist/react --docs",
    "build-storybook:vercel": "cross-env NODE_OPTIONS=--max_old_space_size=8192 DEPLOY_PATH=/ storybook build -o ./dist/react --docs",
    "postbuild-storybook": "yarn rewrite-title && yarn generate-llms-docs",
    "postbuild-storybook:vercel": "yarn rewrite-title",
    "rewrite-title": "node -r ../../scripts/ts-node/src/register ../../scripts/storybook/src/scripts/rewrite-title.ts --title 'Iqvizyon UI React' --distPath ./dist/react",
    "generate-llms-docs": "yarn storybook-llms-extractor --config storybook-llms.config.js",
    "clean": "just-scripts clean",
    "code-style": "just-scripts code-style",
    "just": "just-scripts",
    "lint": "just-scripts lint",
    "type-check": "just-scripts type-check",
    "start": "yarn storybook:docs",
    "storybook": "storybook dev --port 3000",
    "storybook:docs": "yarn storybook --docs",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@iqvizyonui/react-calendar-compat": "*",
    "@iqvizyonui/react-datepicker-compat": "*",
    "@iqvizyonui/react-components": "*",
    "@iqvizyonui/react-theme": "*",
    "@iqvizyonui/react-storybook-addon": "*",
    "@iqvizyonui/react-storybook-addon-export-to-sandbox": "*",
    "@iqvizyonui/theme-designer": "*",
    "@iqvizyonui/recipes": "*",
    "@iqvizyonui/react-timepicker-compat": "*",
    "@griffel/react": "^1.5.32",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-window": "^1.8.6",
    "tslib": "^2.1.0",
    "react-hook-form": "^5.7.2",
    "@iqvizyonui/react-motion-components-preview": "*",
    "@iqvizyonui/react-icons-compat": "*",
    "@iqvizyonui/react-menu-grid-preview": "*"
  }
}
