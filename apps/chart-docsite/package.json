{
  "name": "@iqvizyonui/chart-docsite",
  "version": "1.0.0",
  "private": true,
  "description": "Iqvizyon UI React Charts Preview documentation",
  "scripts": {
    "build-storybook": "storybook build -o ./dist/storybook --docs",
    "build-storybook:docsite": "cross-env DEPLOY_PATH=/iqvui/charts/ storybook build -o ./dist/storybook --docs",
    "build-storybook:vercel": "cross-env NODE_OPTIONS=--max_old_space_size=8192 DEPLOY_PATH=/charts/ storybook build -o ./dist/storybook --docs",
    "postbuild-storybook": "yarn rewrite-title && yarn generate-llms-docs",
    "postbuild-storybook:docsite": "yarn postbuild-storybook",
    "postbuild-storybook:vercel": "yarn rewrite-title",
    "rewrite-title": "node -r ../../scripts/ts-node/src/register ../../scripts/storybook/src/scripts/rewrite-title.ts --title 'Iqvizyon UI Charts' --distPath ./dist/storybook",
    "generate-llms-docs": "yarn storybook-llms-extractor --distPath ./dist/storybook --summaryBaseUrl \"https://ibz-04.github.io/iqvui/charts/\" --summaryTitle \"Iqvizyon UI Charts\" --summaryDescription \"Iqvizyon UI React charts is a set of modern, accessible, interactive, lightweight and highly customizable visualization components.\"",
    "clean": "just-scripts clean",
    "code-style": "just-scripts code-style",
    "just": "just-scripts",
    "type-check": "just-scripts type-check",
    "start": "yarn storybook:docs",
    "storybook": "storybook dev --port 3000",
    "storybook:docs": "yarn storybook --docs",
    "test": "jest --passWithNoTests"
  },
  "dependencies": {
    "@iqvizyonui/react-charts": "*",
    "@iqvizyonui/react-theme": "*",
    "@iqvizyonui/react-storybook-addon": "*",
    "@iqvizyonui/react-storybook-addon-export-to-sandbox": "*",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "tslib": "^2.1.0"
  }
}
