{
  "compilerOptions": {
    "outDir": "dist",
    "target": "ES2015",
    "module": "ESNext",
    "lib": [
      "ES2015",
      "DOM",
      "ES2015.Collection",
      "ES2015.Iterable",
      "ES2015.Symbol.WellKnown"
    ],
    "jsx": "react",
    "declaration": true,
    "sourceMap": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "noUnusedLocals": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "moduleResolution": "bundler",
    "preserveConstEnums": true,
    "types": [
      "jest"
    ],
    "isolatedModules": true
  },
  "include": [
    "src"
  ]
}
