{
  "name": "@iqvizyonui/react-storybook-addon",
  "version": "0.8.2",
  "description": "iqvizyonui react storybook addon",
  "main": "lib-commonjs/index.js",
  "module": "lib/index.js",
  "typings": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/iqvizyon-development/iqv-design-system"
  },
  "license": "MIT",
  "dependencies": {
    "@iqvizyonui/react-aria": "^9.17.15",
    "@iqvizyonui/react-button": "^9.10.3",
    "@iqvizyonui/react-menu": "^9.26.1",
    "@iqvizyonui/react-label": "^9.4.5",
    "@iqvizyonui/react-switch": "^9.7.6",
    "@iqvizyonui/react-text": "^9.6.20",
    "@iqvizyonui/react-link": "^9.8.5",
    "@iqvizyonui/react-provider": "^9.22.20",
    "@iqvizyonui/react-utilities": "^9.27.1",
    "@iqvizyonui/react-theme": "^9.2.3",
    "@fluentui/react-icons": "^2.0.245",
    "@iqvizyonui/react-shared-contexts": "^9.26.4",
    "@iqvizyonui/react-spinner": "^9.8.6",
    "@iqvizyonui/react-toast": "^9.8.3",
    "@griffel/react": "^1.5.32",
    "@swc/helpers": "^0.5.1"
  },
  "peerDependencies": {
    "@storybook/addon-docs": "^9.1.17",
    "@storybook/icons": "^1.3.2",
    "@storybook/react-webpack5": "^9.1.17",
    "@types/react-dom": ">=16.9.0 <20.0.0",
    "@types/react": ">=16.14.0 <20.0.0",
    "react-dom": ">=16.14.0 <20.0.0",
    "react": ">=16.14.0 <20.0.0",
    "storybook": "^9.1.17"
  },
  "beachball": {
    "disallowedChangeTypes": [
      "major",
      "prerelease"
    ]
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "node": "./lib-commonjs/index.js",
      "import": "./lib/index.js",
      "require": "./lib-commonjs/index.js"
    },
    "./preset": "./preset.js",
    "./styles.css": "./dist/styles.css",
    "./package.json": "./package.json"
  },
  "sideEffects": [
    "./dist/styles.css"
  ],
  "files": [
    "*.md",
    "dist/*.d.ts",
    "dist/styles.css",
    "lib",
    "lib-commonjs",
    "preset.js"
  ]
}
