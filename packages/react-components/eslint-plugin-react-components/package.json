{
  "name": "@iqvizyonui/eslint-plugin-react-components",
  "version": "0.4.0",
  "description": "ESLint plugin and custom rules for Iqvizyon UI components",
  "main": "./lib-commonjs/index.js",
  "type": "commonjs",
  "typings": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/iqvizyon-development/iqv-design-system"
  },
  "license": "MIT",
  "devDependencies": {
    "eslint-plugin-eslint-plugin": "6.4.0"
  },
  "dependencies": {
    "@typescript-eslint/utils": "^8.46.2",
    "@swc/helpers": "^0.5.1"
  },
  "peerDependencies": {
    "typescript-eslint": ">= 8.46.2",
    "eslint": ">= 8.0.0",
    "typescript": ">= 5.0.0"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./lib-commonjs/index.js",
      "default": "./lib-commonjs/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "*.md",
    "dist/*.d.ts",
    "lib-commonjs",
    "lib"
  ]
}
