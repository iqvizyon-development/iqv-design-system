{
  "compilerOptions": {
    "outDir": "lib",
    "target": "es6",
    "module": "ESNext",
    "strict": true,
    "jsx": "react",
    "declaration": true,
    "sourceMap": true,
    "importHelpers": true,
    "noUnusedLocals": true,
    "moduleResolution": "bundler",
    "preserveConstEnums": true,
    "lib": [
      "ES2019",
      "DOM"
    ],
    "types": [
      "jest"
    ],
    "isolatedModules": true
  },
  "include": [
    "src"
  ]
}
